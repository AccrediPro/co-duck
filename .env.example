# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Supabase Realtime (for real-time messaging)
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Webhook Secret
# Create a webhook in Clerk Dashboard pointing to /api/webhooks/clerk
# Subscribe to events: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk URLs (optional - defaults shown)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe Payments
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret (for payment webhooks)
# Create a webhook in Stripe Dashboard pointing to /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend Email Service
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_...

# Cron Job Secret
# Used to secure cron endpoints like session reminders
# Generate a random string (e.g., openssl rand -hex 32)
CRON_SECRET=your_cron_secret_here
